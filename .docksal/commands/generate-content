#!/usr/bin/env bash

#: exec_target = cli

## Generate sample content using DNS Default Content recipe
##
## Usage: fin generate-content

# Abort if anything fails
set -e

# PROJECT_ROOT is set as env variable in cli
DRUPAL_PATH="${PROJECT_ROOT}/drupal"

echo "Generating sample content using DNS Default Content recipe..."

cd "${DRUPAL_PATH}"

echo "Installing DNS Default Content recipe package..."
composer require willjackson/dns_default_content

echo "Running DNS Default Content recipe..."
drush recipe ../recipes/dns_default_content

echo "Sample content generation complete!"