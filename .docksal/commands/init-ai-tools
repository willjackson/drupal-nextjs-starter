#!/usr/bin/env bash

#: exec_target = cli

## Initialize install ai tools
##
## Usage: fin init-ai-tools


# Abort if anything fails
set -e

#-------------------------- Settings --------------------------------

# PROJECT_ROOT is set as env variable in cli
DRUPAL_PATH="${PROJECT_ROOT}/drupal"
NEXTJS_PATH="${PROJECT_ROOT}/web"
SITE_DIRECTORY="default"
SITEDIR_PATH="${DRUPAL_PATH}/web/sites/${SITE_DIRECTORY}"
OPENAI_KEY_PATH="${DRUPAL_PATH}/private/keys"
OPENAI_KEY_FILE="${OPENAI_KEY_PATH}/openai_provider.key"
DOCKSAL_SETTINGS_FILE="${PROJECT_ROOT}/.docksal/etc/conf/settings.php"
PRIVATE_PATH="${DRUPAL_PATH}/private"

#-------------------------- END: Settings --------------------------------

#-------------------------- Functions --------------------------------

# Check and setup OpenAI API Key
setup_openai_key() {
	echo "Setting up OpenAI API Key..."

	# Create the keys directory if it doesn't exist
	mkdir -p "${OPENAI_KEY_PATH}"

	# Check if OPEN_AI_API_KEY variable exists and is not empty
	if [[ -n "${OPEN_AI_API_KEY}" ]]; then
		echo "Found OpenAI API Key in environment variable."
		echo "${OPEN_AI_API_KEY}" > "${OPENAI_KEY_FILE}"
		echo "OpenAI API Key written to ${OPENAI_KEY_FILE}"
	else
		echo "OpenAI API Key not found in environment variable."
		echo -n "Please provide your OpenAI API Key: "
		read -s openai_key
		echo

		if [[ -z "${openai_key}" ]]; then
			echo "Error: OpenAI API Key cannot be empty."
			exit 1
		fi

		echo "${openai_key}" > "${OPENAI_KEY_FILE}"
		echo "OpenAI API Key written to ${OPENAI_KEY_FILE}"
	fi

	# Set appropriate permissions
	chmod 600 "${OPENAI_KEY_FILE}"
}

# Install AI packages via composer
install_ai_packages() {
	echo "Installing AI packages via composer..."
	cd "${DRUPAL_PATH}"

	echo "Installing drupal/saplings_ai_agents..."
	composer require drupal/saplings_ai_agents

	echo "Installing drupal/saplings_ai_mcp..."
	composer require drupal/saplings_ai_mcp

	drush cr;

}

# Install AI agents recipe only
install_ai_agents_recipe() {
	echo "Installing AI agents recipe..."
	cd "${DRUPAL_PATH}"

	echo "Installing saplings_ai_agents recipe..."
	drush recipe ../recipes/saplings_ai_agents
}

# Check for MCP environment variables and provide instructions
check_mcp_environment() {
	if [[ -z "${MCP_ADMIN_USER}" || -z "${MCP_ADMIN_PASS}" ]]; then
		echo ""
		echo "============================================================"
		echo "MCP Environment Variables Required"
		echo "============================================================"
		echo ""
		echo "To install the MCP recipe, you need to set the following environment variables:"
		echo "  - MCP_ADMIN_USER"
		echo "  - MCP_ADMIN_PASS"
		echo ""
		echo "Please follow these steps:"
		echo "1. Copy the example environment file:"
		echo "   cp .docksal/docksal.env .docksal/docksal-local.env"
		echo ""
		echo "2. Edit .docksal/docksal-local.env and add your MCP admin credentials:"
		echo "   MCP_ADMIN_USER=your_unique_mcp_admin_username"
		echo "   MCP_ADMIN_PASS=your_secure_password_here"
		echo ""
		echo "3. Restart your Docksal environment to load the new variables:"
		echo "   fin restart"
		echo ""
		echo "4. Run the MCP installation command:"
		echo "   fin init-mcp"
		echo ""
		echo "============================================================"
		return 1
	fi
	return 0
}

# Setup private filesystem configuration
setup_private_filesystem() {
	echo "Setting up private filesystem..."

	# Create private directory and set permissions
	echo "Creating and configuring private directory..."
	mkdir -p "${PRIVATE_PATH}"
	chmod 777 "${PRIVATE_PATH}"
	echo "Private directory created and configured at ${PRIVATE_PATH}"
}

#-------------------------- END: Functions --------------------------------

#-------------------------- Execution --------------------------------

echo "Initializing AI features for Drupal site..."

# Setup OpenAI API Key
setup_openai_key

# Install AI packages
install_ai_packages

# Setup private filesystem
setup_private_filesystem

# Install AI agents recipe
install_ai_agents_recipe

# Check for MCP environment variables
if ! check_mcp_environment; then
	echo "AI agents initialization completed successfully!"
	echo "Please follow the instructions above to complete MCP setup."
else
	echo "MCP environment variables are set. You can now run 'fin init-mcp' to install the MCP recipe."
	echo "AI agents initialization completed successfully!"
fi

#-------------------------- END: Execution --------------------------------