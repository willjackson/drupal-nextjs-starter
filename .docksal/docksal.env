# This is a shared configuration file that is intended to be stored in the project repo.
# To override a variable locally:
# - create .docksal/docksal-local.env file and local variable overrides there
# - add .docksal/docksal-local.env to .gitignore

# Use the default Docksal stack without database
DOCKSAL_STACK=default
DOCROOT=web

# CLI Image Version
#CLI_IMAGE='docksal/cli:php8.3-3'

# Node environment
NODE_ENV=development

# Enable/disable xdebug
XDEBUG_ENABLED=0

# MCP Config
#MCP_ADMIN_USER=mcp_admin
#MCP_ADMIN_PASS=secure_password_goes_here
