# Ignore directories generated by Composer
/drush/contrib/
/drush/Commands/
/vendor/
/web/libraries/
/web/core/
/web/modules/contrib/
/web/modules/README.txt
/web/themes/contrib/
/web/themes/README.txt
/web/profiles/contrib/
/web/profiles/README.txt
/web/private/scripts/quicksilver
/console/
/recipes/

# Composer lock
composer.lock

# Ignore scaffold files
/.drush-lock-update
/.gitattributes
/pantheon.upstream.yml
/web/.eslintrc.json
/web/INSTALL.txt
/web/README.txt
/web/example.gitignore
/web/.csslintrc
/web/.editorconfig
/web/.eslintignore
/web/.eslintrc
/web/.htaccess
/web/.ht.router.php
/web/autoload.php
/web/index.php
/web/robots.txt
/web/sites/default/default.services.pantheon.preproduction.yml
/web/sites/default/default.services.yml
/web/sites/default/default.settings.php
/web/sites/default/settings.pantheon.php
/web/sites/development.services.yml
/web/sites/example.settings.local.php
/web/sites/example.sites.php
/web/sites/README.txt
/web/update.php
/web/web.config
/web/README.md

# Ignore Drupal's file directory
/web/sites/default/files

# Ignore Drupal's private file directory (file_private_path = '../private')
/private/

# Pantheon commits a settings.php for environment-specific settings.
# Place local settings in settings.local.php
/web/sites/*/settings.local.php
/web/sites/*/settings.local.*.php
/web/sites/*/services*.yml
!/web/sites/*/services.pantheon.*.yml
!/web/sites/*/services.yml

# Ignore SimpleTest multi-site environment.
/web/sites/simpletest

# Ignore files generated by PhpStorm
/.idea

# Packages #
############
*.7z
*.dmg
*.gz
*.bz2
*.iso
*.jar
*.rar
*.tar
*.zip
*.tgz

# Logs and databases #
######################
*.log
*.sql

# OS generated files #
######################
.DS_Store*
ehthumbs.db
Thumbs.db
._*

# Vim generated files #
#######################
*.un~

# SASS #
########
.sass-cache

/.lando.local.yml

# NPM and theme files #
#######################
/node/node_modules
/web/themes/custom/*/dist

# IDE settings #
.vscode/
.docksal/docksal-local.env
.docksal/docksal-local.yml
.claude
web/sites/default/settings.php
