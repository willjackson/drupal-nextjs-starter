# Drupal Backend Configuration
# Copy this file to .env.local or .env.development and update with your values
# See https://next-drupal.org/docs/environment-variables

# Required
NEXT_PUBLIC_DRUPAL_BASE_URL=http://localhost:8080
NEXT_IMAGE_DOMAIN=localhost:8080

# Authentication
DRUPAL_CLIENT_ID=default_consumer
DRUPAL_CLIENT_SECRET=your-drupal-client-secret

# Required for On-demand Revalidation
DRUPAL_REVALIDATE_SECRET=nextjs-drupal

# Required for Draft Mode: Drupal Preview Secret (for draft content preview)
# This should match the preview secret configured in your Drupal NextJS module
DRUPAL_PREVIEW_SECRET=nextjs-drupal
