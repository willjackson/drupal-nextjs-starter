#!/bin/bash

## Description: Initialize the full stack and site (mirrors `fin init`)
## Usage: init [--content] [--ai]
## Example: "ddev init --content --ai"
## Flags: [{"Name":"content","Usage":"Install sample content automatically"},{"Name":"ai","Usage":"Install AI Tools automatically"}]

# Abort if anything fails
set -e

# Parse command line arguments
INSTALL_CONTENT=false
INSTALL_AI=false

while [[ $# -gt 0 ]]; do
  case $1 in
    --content)
      INSTALL_CONTENT=true
      shift
      ;;
    --ai)
      INSTALL_AI=true
      shift
      ;;
    *)
      echo "Unknown option: $1"
      echo "Usage: ddev init [--content] [--ai]"
      exit 1
      ;;
  esac
done

# Stack initialization
echo "Initializing stack..."
ddev start

# Site initialization
echo "Initializing site..."
ddev install-drush
ddev init-site
ddev init-drupal-nextjs

# Generate sample content if requested
echo ""
if [[ $INSTALL_CONTENT == true ]]; then
    echo "Generating sample content..."
    ddev generate-content
else
    echo "Skipping sample content generation (use --content flag to install automatically)"
fi

echo "Starting development server in background..."
ddev develop --background

echo "Site initialization complete!"
echo ""

# Install AI Tools if requested
if [[ $INSTALL_AI == true ]]; then
    echo "Installing AI Tools..."
    ddev init-ai
else
    echo "Skipping AI Tools installation (use --ai flag to install automatically)"
fi

echo ""
ddev show-links
