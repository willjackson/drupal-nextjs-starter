#!/bin/bash

## Description: Run the Next.js development server (in a tmux session)
## Usage: develop [--background]
## Example: "ddev develop" or "ddev develop --background"

# Abort if anything fails
set -e

# Parse flags
attach_session=true
for arg in "$@"; do
  case $arg in
    --background)
      attach_session=false
      ;;
  esac
done

# tmux is installed via webimage_extra_packages in .ddev/config.nextjs.yaml.
if ! command -v tmux &> /dev/null; then
  echo "tmux could not be found. Add it via webimage_extra_packages and run 'ddev restart'."
  exit 1
fi

# Check if the tmux session already exists
if tmux has-session -t BlogDev 2>/dev/null; then
  echo "BlogDev already running."
  if $attach_session; then
    echo "Connecting to BlogDev..."
    tmux attach-session -t BlogDev
  else
    echo "BlogDev will continue running in the background."
  fi
  exit 0
fi

# Start tmux with a new session named 'BlogDev'
tmux new-session -d -s BlogDev -n 'NextJS'

# Start the Next.js development server on port 3000, bound to all interfaces so
# the nginx reverse proxy (primary URL) can reach it.
tmux send-keys -t BlogDev:0 'cd /var/www/html/web && npm run dev -- -H 0.0.0.0 -p 3000 2>&1 | tee /tmp/nextjs-dev.log' C-m

# Ensure tmux prefix key is Ctrl + B
tmux unbind C-b
tmux set -g prefix C-b
tmux bind C-b send-prefix

# Bind 'q' to run the stop script
tmux bind-key q confirm-before -p "Are you sure you want to kill this session? (y/n)" "run-shell '/mnt/ddev_config/commands/web/develop-stop'"

# Attach to the tmux session if not running in background
if $attach_session; then
  tmux attach-session -t BlogDev
else
  echo "Session 'BlogDev' started in background."
  echo "Next.js will be available at https://${VIRTUAL_HOST} (and https://${VIRTUAL_HOST}:3000)."
fi
