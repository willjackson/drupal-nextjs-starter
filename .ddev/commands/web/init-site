#!/bin/bash

## Description: Initialize/install the Drupal 11 + Next.js site (composer, npm, drush si)
## Usage: init-site
## Example: "ddev init-site"

# Abort if anything fails
set -e

#-------------------------- Settings --------------------------------

PROJECT_ROOT="/var/www/html"
export PATH="${PROJECT_ROOT}/drupal/vendor/bin:${PATH}"

DRUPAL_PATH="${PROJECT_ROOT}/drupal"
NEXTJS_PATH="${PROJECT_ROOT}/web"
SITE_DIRECTORY="default"
SITEDIR_PATH="${DRUPAL_PATH}/web/sites/${SITE_DIRECTORY}"

#-------------------------- END: Settings --------------------------------

#-------------------------- Functions --------------------------------

# Install Next.js dependencies
init_nextjs() {
	echo "Installing Next.js dependencies..."
	cd "${NEXTJS_PATH}"
	npm install
}

# Initialize local settings files
init_drupal_settings () {
	echo 'Setting up local settings files...'

	# DDEV creates settings.php from default.settings.php on first start, with the
	# settings.local.php include commented out. Make sure an active include exists.
	if ! grep -qE '^[^#]*include.*settings\.local\.php' "${SITEDIR_PATH}/settings.php"; then
		echo "Enabling settings.local.php include in settings.php..."
		cat >> "${SITEDIR_PATH}/settings.php" <<'PHP'

// Load local development override configuration (symlinked by `ddev init-site`).
if (file_exists($app_root . '/' . $site_path . '/settings.local.php')) {
  include $app_root . '/' . $site_path . '/settings.local.php';
}
PHP
	else
		echo "settings.local.php include already present."
	fi

	# Create the symlink to our shared local settings.
	echo 'Linking settings.local.php for local dev...'
	ln -sf "${PROJECT_ROOT}/.ddev/etc/conf/settings.php" "${SITEDIR_PATH}/settings.local.php"
}

# Initialize Next.js environment
init_nextjs_env() {
	echo "Setting up Next.js environment..."
	cd "${NEXTJS_PATH}"
	if [ ! -f .env.local ] && [ -f .env.example ]; then
		cp .env.example .env.local
		# Point the frontend at the Drupal hostname (mirrors Docksal init-site).
		sed -i "s/localhost:8080/drupal.${VIRTUAL_HOST}/g" .env.local
		echo ".env.local created and configured"
	elif [ -f .env.local ]; then
		echo ".env.local already exists, skipping creation"
	else
		echo "Warning: .env.example not found"
	fi
}

# Install Drupal dependencies and initialize site
init_drupal() {
	echo "Installing Drupal dependencies..."
	cd "${DRUPAL_PATH}"
	composer install

	# Initialize local Drupal settings
	init_drupal_settings

	echo "Installing Drupal site..."
	drush site:install standard --site-name="Drupal 11" --yes

	echo "Clearing caches..."
	drush cache:rebuild
}

# Fix file/folder permissions
fix_permissions() {
	echo "Setting up permissions..."
	mkdir -p "${SITEDIR_PATH}/files/private"
	chmod 755 "${SITEDIR_PATH}"
	chmod 755 "${SITEDIR_PATH}/files/private"
}

#-------------------------- END: Functions --------------------------------

#-------------------------- Execution --------------------------------

echo "Initializing Drupal 11 + Next.js site..."

init_nextjs
init_nextjs_env
init_drupal
fix_permissions

#-------------------------- END: Execution --------------------------------
